{
  "name": "selector",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "dev": "npm run build:lib && npm run start",
    "build": "ng build --base-href=/selector/",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "build:lib": "ng-packagr -p projects/some-angular-utils/selector/ng-package.json",
    "start:storybook": "ng run @some-angular-utils/selector:storybook",
    "build:storybook": "ng run @some-angular-utils/selector:build-storybook"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.9.3",
  "dependencies": {
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@storybook/preview-api": "^8.6.14",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/architect": "^0.2100.0",
    "@angular-devkit/build-angular": "^21.0.0",
    "@angular-devkit/core": "^21.0.0",
    "@angular/build": "^21.0.4",
    "@angular/cli": "^21.0.4",
    "@angular/compiler-cli": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0",
    "@storybook/angular": "^10.2.3",
    "jsdom": "^27.1.0",
    "ng-packagr": "^21.0.0",
    "storybook": "^10.2.3",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}